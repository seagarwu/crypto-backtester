{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EngineerReferenceCache",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["name", "source_type", "summary"],
    "properties": {
      "name": { "type": "string" },
      "source_type": { "type": "string" },
      "url": { "type": "string" },
      "summary": { "type": "string" },
      "tags": {
        "type": "array",
        "items": { "type": "string" }
      },
      "patterns": {
        "type": "array",
        "items": { "type": "string" }
      },
      "constraints": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "additionalProperties": true
  }
}
